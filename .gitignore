# Local secrets / environment — never commit
.env
.env.*
# ...but keep the committed example templates
!.env.example
!.env*.example

# Rails runtime artifacts
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/storage/*

# Test / coverage output
/coverage
spec/examples.txt

# Dependencies
/node_modules

# OS / editor cruft
.DS_Store
.idea/
.vscode/
.claude/
