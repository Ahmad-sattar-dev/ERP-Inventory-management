# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and is loaded by dotenv-rails (and docker-compose).

# --- Rails ---------------------------------------------------------------
RAILS_ENV=development
# Generate one with: bundle exec rails secret
SECRET_KEY_BASE=changeme

# --- PostgreSQL ----------------------------------------------------------
# DATABASE_HOST is set to `db` automatically inside docker-compose.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=apparel_inventory_development

# --- Redis / Sidekiq -----------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Active Record encryption (Integration credentials) ------------------
# Demo defaults are used if unset; ALWAYS set real values in production.
# Generate with: bin/rails db:encryption:init  (or any random 32+ char strings)
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=

# --- API auth ------------------------------------------------------------
# Token created by db/seeds.rb for the default API key. Send it as:
#   Authorization: Bearer <token>
SEED_API_TOKEN=dev-token-please-change-me

# --- CORS ----------------------------------------------------------------
# Comma-separated list of allowed origins, or * for all (dev only).
CORS_ORIGINS=*

# --- Third-party integrations (optional for local dev) -------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
EASYPOST_API_KEY=
SHIPSTATION_API_KEY=
SENTRY_DSN=
