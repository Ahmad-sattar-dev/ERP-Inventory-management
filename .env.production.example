# Production environment template. On the server:
#   cp .env.production.example .env.production
# then fill in EVERY value below. NEVER commit .env.production.

# --- Domain (used by Caddy for automatic HTTPS) --------------------------
DOMAIN=erp.yourdomain.com

# --- Rails ---------------------------------------------------------------
RAILS_ENV=production
# Generate with: docker compose -f docker-compose.prod.yml run --rm web bin/rails secret
SECRET_KEY_BASE=

# --- Active Record encryption (Integration credentials) ------------------
# Generate three distinct 32+ char random strings, e.g.:
#   openssl rand -hex 32
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=

# --- PostgreSQL ----------------------------------------------------------
DATABASE_USER=apparel_inventory
# Use a long random password: openssl rand -base64 24
DATABASE_PASSWORD=
DATABASE_NAME=apparel_inventory_production

# --- API auth ------------------------------------------------------------
# The seeded API key token. Use a strong value: openssl rand -hex 24
SEED_API_TOKEN=

# --- CORS ----------------------------------------------------------------
# Lock this to your real front-end origin(s) — do NOT use * in production.
CORS_ORIGINS=https://app.yourdomain.com

# --- Performance tuning (optional) ---------------------------------------
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5
SIDEKIQ_CONCURRENCY=5
